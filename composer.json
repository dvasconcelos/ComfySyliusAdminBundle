{
    "name": "oliverde8/comfy-sylius-admin-bundle",
    "type": "library",
    "description": "Add interfaces to edit comfy configurations in sylius admin.",
    "license": "MIT",
    "authors": [
        {
            "name": "Oliver de Cramer",
            "homepage": "http://oliver-decramer.com"
        },
        {
            "name": "DE VASCONCELOS Dominique "
        }
    ],
    "require": {
        "php": ">=8.0",
        "oliverde8/comfy-bundle": "dev-master",
        "sylius/admin-bundle": "^1.11|^2.0"
    },
    "autoload": {
        "psr-4": {
            "oliverde8\\ComfySyliusAdminBundle\\": "."
        }
    },
    "require-dev": {
        "rector/rector": "^2.3"
    },
    "repositories": {
        "comfyBundle": {
            "type": "vcs",
            "url": "https://github.com/dvasconcelos/comfyBundle"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
